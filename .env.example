APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

AI_QUOTATION_BASE_URL=
AI_QUOTATION_PARSE_ENDPOINT=parse
AI_QUOTATION_API_KEY=
AI_QUOTATION_TIMEOUT=120

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_VISION_MODEL=deepseek-vl2

# Product Catalog Research module (DeepSeek client + research pipeline).
# Never commit real secret values.
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_TIMEOUT=120
DEEPSEEK_MAX_RETRIES=3
DEEPSEEK_RATE_LIMIT=30
CATALOG_RESEARCH_PROVIDER=deepseek
# Leave as "default" so the standard queue worker processes research jobs.
CATALOG_RESEARCH_QUEUE=default
CATALOG_RESEARCH_BATCH_SIZE=5
CATALOG_RESEARCH_MANUFACTURERS_BATCH=5
CATALOG_RESEARCH_SERIES_BATCH=10
CATALOG_RESEARCH_VARIANTS_BATCH=20
CATALOG_RESEARCH_MAX_CONCURRENT_JOBS=3
CATALOG_SOURCE_REFRESH_DAYS=180

# Vision API — DeepSeek does NOT support images; use a vision-capable service.
# Option 1 (recommended, free): Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.0-flash

# Option 2 (free): Groq — https://console.groq.com
GROQ_API_KEY=
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Option 3: Generic OpenAI-compatible endpoint (OpenAI, OpenRouter, etc.)
VISION_API_KEY=
VISION_BASE_URL=https://openrouter.ai/api/v1
VISION_MODEL=google/gemini-flash-1.5-8b

VITE_APP_NAME="${APP_NAME}"

# Reading PDF BOQs. Without a key the app falls back to OCR.space's shared
# demo key, which is rate-limited and will fail under real use.
# Free key: https://ocr.space/ocrapi/freekey
OCRSPACE_API_KEY=
